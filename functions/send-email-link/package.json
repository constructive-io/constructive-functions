{
  "name": "@constructive-io/send-email-link-fn",
  "version": "0.2.18",
  "description": "Knative function to send email links (invite, password reset, email verification) using Constructive jobs",
  "author": "Constructive",
  "private": true,
  "main": "dist/index.js",
  "directories": {
    "lib": "src",
    "test": "__tests__"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json -w",
    "clean": "rimraf dist",
    "lint": "eslint . --fix",
    "pretest": "tsc",
    "test": "jest --forceExit __tests__/index.test.ts",
    "test:inner": "jest __tests__/index.test.ts",
    "build:test-image": "docker build -t constructive/send-email-link-test:v1 -f ../_runtimes/node/Dockerfile.test ."
  },
  "dependencies": {
    "@constructive-io/knative-job-fn": "latest",
    "@launchql/mjml": "0.1.1",
    "@launchql/postmaster": "0.1.4",
    "@launchql/styled-email": "0.1.0",
    "@pgpmjs/env": "latest",
    "graphql-request": "^7.1.2",
    "graphql-tag": "^2.12.6",
    "kubernetesjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.4",
    "jest": "^29.7.0",
    "pgsql-test": "latest",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6"
  }
}