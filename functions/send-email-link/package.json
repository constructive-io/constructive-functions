{
  "name": "@constructive-io/send-email-link-fn",
  "version": "1.1.0",
  "description": "Knative function to send email links (invite, password reset, email verification) using Constructive jobs",
  "author": "Constructive",
  "private": true,
  "main": "dist/index.js",
  "directories": {
    "lib": "src",
    "test": "__tests__"
  },
  "scripts": {
