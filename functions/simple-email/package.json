{
  "name": "@constructive-io/simple-email-fn",
  "version": "0.2.19",
  "description": "Simple Knative email function that sends emails directly from job payload",
  "author": "Constructive",
  "private": true,
  "main": "dist/index.js",
  "directories": {
    "lib": "src",
    "test": "__tests__"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json -w",
    "clean": "rimraf dist",
    "lint": "eslint . --fix",
    "pretest": "tsc",
    "test": "jest --forceExit __tests__/index.test.ts"
  },
  "dependencies": {
    "@constructive-io/knative-job-fn": "latest",
    "@launchql/postmaster": "latest",
    "@pgpmjs/env": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/jest": "latest",
    "jest": "latest",
    "ts-jest": "latest",
    "typescript": "latest",
    "kubernetesjs": "latest",
    "pgsql-test": "latest",
    "rimraf": "latest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "modulePathIgnorePatterns": [
      "<rootDir>/dist/",
      "<rootDir>/node_modules/"
    ]
  }
}