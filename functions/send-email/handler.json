{
  "name": "send-email",
  "version": "1.6.4",
  "type": "node-graphql",
  "port": 8081,
  "taskIdentifier": "send-email",
  "scope": "platform",
  "description": "Sends transactional emails via Mailgun or SMTP",
  "requiredSecrets": [
    { "name": "MAILGUN_API_KEY", "required": false },
    { "name": "MAILGUN_DOMAIN", "required": false },
    { "name": "MAILGUN_FROM", "required": false }
  ],
  "requiredConfigs": [
    { "name": "EMAIL_SEND_USE_SMTP", "required": false },
    { "name": "SMTP_HOST", "required": false },
    { "name": "SMTP_PORT", "required": false },
    { "name": "SMTP_FROM", "required": false },
    { "name": "SEND_EMAIL_DRY_RUN", "required": false }
  ],
  "dependencies": {
    "@constructive-io/postmaster": "^1.5.2",
    "@pgpmjs/env": "^2.15.3",
    "@pgpmjs/logger": "^2.4.3",
    "simple-smtp-server": "^0.7.3"
  }
}
