{
  "name": "@constructive-io/fn-runtime",
  "version": "1.2.0",
  "description": "Runtime for Constructive functions — wraps a handler in an Express app with GraphQL client, logging, and job callback support.",
  "author": "Constructive <developers@constructive.io>",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy",
    "copy": "copyfiles -f ../../LICENSE README.md package.json dist",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@constructive-io/fn-types": "workspace:^",
    "@constructive-io/knative-job-fn": "workspace:^",
    "@pgpmjs/logger": "^2.4.3",
    "graphql-request": "^7.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.4",
    "copyfiles": "^2.4.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.1.6"
  }
}
