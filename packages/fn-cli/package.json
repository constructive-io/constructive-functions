{
  "name": "@constructive-io/fn-cli",
  "version": "0.1.0",
  "description": "Thin command-line wrapper for the Constructive Functions toolkit. Exposes the `fn` executable.",
  "author": "Constructive <developers@constructive.io>",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "fn": "bin/fn.js"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy && pnpm run copy:templates && chmod +x dist/bin/fn.js",
    "copy": "copyfiles -f ../../LICENSE README.md package.json dist",
    "copy:templates": "copyfiles -a \"templates/**/*\" dist",
    "clean": "rimraf dist",
    "test": "jest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@constructive-io/fn-client": "workspace:^",
    "genomic": "^5.3.11",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.10.4",
    "copyfiles": "^2.4.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.2.5",
    "typescript": "^5.1.6"
  }
}
